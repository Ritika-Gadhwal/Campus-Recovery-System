PORT=5000
MONGO_URI=mongodb://127:0:0:1:27017/college-lost-found
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Cloudinary Config (Optional, falls back to local uploads if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP Config for Nodemailer (Optional, falls back to logging if empty)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@collegeportal.edu

# Allowed domains for student registration (comma separated)
ALLOWED_EMAIL_DOMAINS=edu,college.edu,university.edu,student.edu,mit.edu,stanford.edu

# Gemini API Key (Optional, falls back to custom local text matching if empty)
GEMINI_API_KEY=
